# Archivo de referencia para variables de entorno del servidor.
# La aplicacion no carga automaticamente un archivo .env local.
# En XAMPP/WampServer use preferiblemente:
#   php database/tools/configure_mysql_credentials.php
# o cree app/Config/config.local.php desde app/Config/config.local.example.php.
# Copiar este archivo como .env no cambia la configuracion por si solo.

APP_BASE_URL=/CMDB_Semestral/public
DB_HOST=localhost
DB_NAME=cmdb_integral
DB_USER=root
DB_PASSWORD=
CMDB_INTEGRITY_KEY=CAMBIAR_POR_UNA_CLAVE_ALEATORIA_LARGA
CMDB_LEGACY_HMAC_KEY=
APP_ENV=development
